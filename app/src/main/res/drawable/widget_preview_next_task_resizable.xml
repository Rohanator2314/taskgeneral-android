<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="#E0E0E0" />
        </shape>
    </item>
    <!-- Title -->
    <item
        android:top="12dp"
        android:left="12dp"
        android:right="12dp"
        android:height="12dp">
        <shape android:shape="rectangle">
            <solid android:color="#757575" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <!-- Task description -->
    <item
        android:top="32dp"
        android:left="12dp"
        android:right="12dp"
        android:height="40dp">
        <shape android:shape="rectangle">
            <solid android:color="#424242" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <!-- Project text -->
    <item
        android:top="80dp"
        android:left="12dp"
        android:width="60dp"
        android:height="8dp">
        <shape android:shape="rectangle">
            <solid android:color="#9E9E9E" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <!-- Start button -->
    <item
        android:width="24dp"
        android:height="24dp"
        android:bottom="12dp"
        android:right="48dp"
        android:gravity="right|bottom">
        <shape android:shape="oval">
            <solid android:color="#2196F3" />
        </shape>
    </item>
    <!-- Complete button -->
    <item
        android:width="24dp"
        android:height="24dp"
        android:bottom="12dp"
        android:right="12dp"
        android:gravity="right|bottom">
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="#4CAF50" />
        </shape>
    </item>
</layer-list>
